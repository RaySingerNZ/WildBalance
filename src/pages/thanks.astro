---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import hero1Image from '../assets/img/WildBalance_Hero1.jpg';
---

<BaseLayout
	title="Thanks | Wild Balance"
	description="Thanks for registering your interest in the first Wild Balance release."
	image={hero1Image.src}
>
	<Section
		eyebrow="Message received"
		title="Thanks - we’ve got your message."
		intro="We’ll be in touch as the first Wild Balance release comes together."
		narrow
	/>
</BaseLayout>
