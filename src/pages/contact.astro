---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import InterestForm from '../components/InterestForm.astro';
---

<BaseLayout
	title="Contact / Register Interest | Wild Balance"
	description="Register your interest in Wild Balance handmade merino clothing from Christchurch, New Zealand."
>
	<Section
		eyebrow="Contact / Register interest"
		title="Be part of the Wild Balance launch."
		intro="Follow the first garment, get launch updates, and back a proper New Zealand-made merino brand. For made-to-order enquiries, include the terrain, season, and layer you are thinking about."
	>
		<div class="grid gap-10 lg:grid-cols-[0.85fr_1.15fr] lg:items-start">
			<div class="material-panel hidden min-h-[24rem] md:block" aria-hidden="true"></div>
			<div class="border border-[#2c271f]/15 bg-[#e4d8c7] p-6 sm:p-8">
				<InterestForm />
			</div>
		</div>
	</Section>
</BaseLayout>
