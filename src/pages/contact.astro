---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import WaitlistForm from '../components/WaitlistForm.astro';
---

<BaseLayout
	title="Contact / Waitlist | Wild Balance"
	description="Join the Wild Balance waitlist for handmade merino clothing updates from Christchurch, New Zealand."
>
	<Section
		eyebrow="Contact / Waitlist"
		title="Hear about the first Christchurch-made release."
		intro="Join the waitlist for launch updates, hoodie notes, and first availability. For made-to-order enquiries, include the terrain, season, and layer you are thinking about."
	>
		<div class="grid gap-10 lg:grid-cols-[0.85fr_1.15fr] lg:items-start">
			<div class="material-panel min-h-[24rem]" aria-hidden="true"></div>
			<div class="border border-[#2c271f]/15 bg-[#e4d8c7] p-6 sm:p-8">
				<WaitlistForm />
			</div>
		</div>
	</Section>
</BaseLayout>
