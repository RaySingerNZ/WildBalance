---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';

const garments = [
	{
		name: 'Merino mid-layer hoodie',
		description: 'The first Wild Balance piece: a do-it-all layer for shoulder-season and winter hunting.',
	},
	{
		name: 'Made one at a time',
		description: 'Designed, cut, sewn, and hand dyed in Christchurch rather than produced offshore.',
	},
	{
		name: 'Built for big country',
		description: 'Warm for glassing, breathable for the climb, and comfortable around camp after dark.',
	},
];
---

<BaseLayout
	title="Garments | Wild Balance"
	description="The first Wild Balance garment is a Christchurch-made merino mid-layer hoodie for hunting."
>
	<Section
		eyebrow="Garments"
		title="First up: a merino mid-layer hoodie."
		intro="This is not a full range yet. The first piece is a do-it-all hoodie for shoulder-season and winter hunting - the one you put on early and keep on all day."
	>
		<div class="grid gap-5 md:grid-cols-3">
			{
				garments.map((garment) => (
					<article class="border border-[#2c271f]/15 bg-[#f8f3e9]">
						<div class="wool-swatch h-56" aria-hidden="true"></div>
						<div class="p-6">
							<h2 class="text-xl font-semibold text-[#2c271f]">{garment.name}</h2>
							<p class="mt-4 text-sm leading-6 text-[#625a4d]">{garment.description}</p>
						</div>
					</article>
				))
			}
		</div>
	</Section>

	<Section
		tone="muted"
		title="Range notes"
		intro="Colours, sizing, and release timing will be confirmed as the first hoodie is finished. No e-commerce yet - register your interest for first availability."
		narrow
	/>
</BaseLayout>
