---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ImageFrame from '../components/ImageFrame.astro';
import Section from '../components/Section.astro';

// Replace these Unsplash URLs with your own field, garment, and workshop images when ready.
const placeholderImages = {
	hero:
		'https://unsplash.com/photos/HVKyHqiXcbw/download?force=true',
	wool:
		'https://images.unsplash.com/photo-1550376026-7375b92bb318?auto=format&fit=crop&q=80&w=1200',
	workshop:
		'https://images.unsplash.com/photo-1753162659622-371949a713ec?auto=format&fit=crop&q=80&w=1400',
};

const practicalNotes = [
	{
		title: 'One at a time',
		text: 'This is not standard off-the-shelf clothing with a local logo stitched on. Each garment is individually made by people who know the work.',
	},
	{
		title: 'By hunters, for hunters',
		text: 'The first pieces are aimed at real hunting days: early starts, long climbs, glassing, camp, and cold weather that shifts quickly.',
	},
	{
		title: 'Built on experience',
		text: 'The makers have over 10 years of full-time clothing experience, including running Morphic Ltd from Christchurch.',
	},
];

const hoodieUses = ['Cold mornings', 'Long climbs', 'Glassing', 'Camp', 'Around the fire'];
---

<BaseLayout
	title="Wild Balance | Soft Fibre. Hard Country."
	description="Designed, cut, sewn, and hand dyed merino outdoor clothing from Christchurch, New Zealand."
>
	<Hero
		eyebrow="Not just designed here. Made here."
		title="Soft Fibre. Hard Country."
		subtitle="Merino clothing designed for the hunt. Sewn, and hand dyed in Christchurch, NZ - one garment at a time."
		support="The first Wild Balance piece is a do-it-all alpine hunting hoodie - built for cold starts, breathable for long climbs, warm while glassing, and comfortable around camp. Register your interest and help launch a proper New Zealand-made hunting brand."
		imageSrc={placeholderImages.hero}
		imageAlt="Placeholder image of a hunter in a hoodie standing in front of a rock wall."
		imageObjectPosition="center"
		primaryHref="/contact"
		primaryLabel="Register your interest"
		secondaryHref="/garments"
		secondaryLabel="First garment"
	/>

	<Section
		tone="muted"
		eyebrow="The Launch - one garment, done properly."
		title="The merino hoodie handcrafted for backcountry adventure."
	>
		<p class="max-w-4xl text-xl font-medium leading-8 text-[#3d372d] sm:text-2xl">
			We are starting with a hoodie because it is the layer alpine hunters live in.
		</p>
		<p class="mt-5 max-w-2xl text-base leading-7 text-[#625a4d] sm:text-lg">
			The focus is simple: merino warmth without unnecessary bulk. 
		</p> 
		<p class="mt-5 max-w-2xl text-base leading-7 text-[#625a4d] sm:text-lg">
			A practical hood for wind and sun, shoulder room for climbing through rough terrain, and a cut that lets you glass without fighting the garment.
		</p>
		<p class="mt-5 max-w-2xl text-base leading-7 text-[#625a4d] sm:text-lg">
			Doubled-over sleeve and body cuffs add durability where it matters, with no scratchy tags or labels in the wrong spot.
		</p>
		<a
			href="/contact"
			class="mt-8 inline-flex border border-[#3a382f]/30 bg-[#f8f3e9]/70 px-5 py-3 text-sm font-semibold text-[#2c271f] transition-colors hover:border-[#3a382f]/60 hover:bg-[#f8f3e9]"
		>
			Get behind the first release
		</a>
		<br />
		<ImageFrame
			src={placeholderImages.wool}
			alt="Placeholder close-up image of wool textile texture."
			aspect="wide"
			objectPosition="center"
		/>
	</Section>

	<Section
		eyebrow="THE FIRST RELEASE"
		title="How to get one."
		intro="The first Wild Balance hoodies will not be pulled from a warehouse shelf. They will be made one at a time for you, with sizing and fit sorted before we start."
	>
		<ol class="grid gap-5 md:grid-cols-2 xl:grid-cols-3">
			<li class="border border-[#2c271f]/15 bg-[#f8f3e9] p-6">
				<h3 class="text-lg font-semibold text-[#2c271f]">
					<span class="mr-2 text-xs font-semibold uppercase tracking-[0.24em] text-[#626b43]">1.</span>
					Register your interest
				</h3>
				<p class="mt-3 text-sm leading-6 text-[#625a4d]">
					Tell us you are keen and we will keep you in the loop as the first hoodie gets closer.
				</p>
			</li>
			<li class="border border-[#2c271f]/15 bg-[#f8f3e9] p-6">
				<h3 class="text-lg font-semibold text-[#2c271f]">
					<span class="mr-2 text-xs font-semibold uppercase tracking-[0.24em] text-[#626b43]">2.</span>
					We get in touch
				</h3>
				<p class="mt-3 text-sm leading-6 text-[#625a4d]">
					We will confirm your size, talk through fit, and check whether small adjustments are
					needed - like sleeve length or body length.
				</p>
			</li>
			<li class="border border-[#2c271f]/15 bg-[#f8f3e9] p-6">
				<h3 class="text-lg font-semibold text-[#2c271f]">
					<span class="mr-2 text-xs font-semibold uppercase tracking-[0.24em] text-[#626b43]">3.</span>
					Pay a deposit
				</h3>
				<p class="mt-3 text-sm leading-6 text-[#625a4d]">
					Once your place is confirmed, a deposit secures your garment.
				</p>
			</li>
			<li class="border border-[#2c271f]/15 bg-[#f8f3e9] p-6">
				<h3 class="text-lg font-semibold text-[#2c271f]">
					<span class="mr-2 text-xs font-semibold uppercase tracking-[0.24em] text-[#626b43]">4.</span>
					We make your hoodie
				</h3>
				<p class="mt-3 text-sm leading-6 text-[#625a4d]">
					Your hoodie is sewn and hand dyed by us in Christchurch.
				</p>
			</li>
			<li class="border border-[#2c271f]/15 bg-[#f8f3e9] p-6">
				<h3 class="text-lg font-semibold text-[#2c271f]">
					<span class="mr-2 text-xs font-semibold uppercase tracking-[0.24em] text-[#626b43]">5.</span>
					Pay the balance
				</h3>
				<p class="mt-3 text-sm leading-6 text-[#625a4d]">
					The remaining amount is paid before delivery or on pick-up.
				</p>
			</li>
			<li class="border border-[#2c271f]/15 bg-[#f8f3e9] p-6">
				<h3 class="text-lg font-semibold text-[#2c271f]">
					<span class="mr-2 text-xs font-semibold uppercase tracking-[0.24em] text-[#626b43]">6.</span>
					Wear it properly
				</h3>
				<p class="mt-3 text-sm leading-6 text-[#625a4d]">
					Around town if you want to show off the dye work, or up in the hills where merino,
					movement, and natural tones actually matter.
				</p>
			</li>
		</ol>
	</Section>

	<section class="bg-[#efe8db] px-5 py-6 sm:px-6 lg:px-8">
		<h2 class="sr-only">Garments in action</h2>
		<div class="mx-auto grid max-w-7xl gap-4 md:grid-cols-3">
			<a href={placeholderImages.hero} target="_blank" rel="noreferrer" class="block">
				<ImageFrame
					src={placeholderImages.hero}
					alt="Placeholder image of hikers moving through alpine terrain beneath snow-covered peaks."
					aspect="square"
					objectPosition="center"
				/>
			</a>
			<a href={placeholderImages.wool} target="_blank" rel="noreferrer" class="block">
				<ImageFrame
					src={placeholderImages.wool}
					alt="Placeholder close-up image of wool textile texture."
					aspect="square"
					objectPosition="center"
				/>
			</a>
			<a href={placeholderImages.workshop} target="_blank" rel="noreferrer" class="block">
				<ImageFrame
					src={placeholderImages.workshop}
					alt="Placeholder image of garment makers working in a sewing workshop."
					aspect="square"
					objectPosition="center"
				/>
			</a>
		</div>
	</section>

	<Section
		eyebrow="FEW AND FAR BETWEEN"
		title="We're not offshoring the hard part."
		intro=""
	>
		<div class="grid gap-10 lg:grid-cols-[1.05fr_0.95fr] lg:items-center">
			<div class="space-y-5">
				<p class="text-lg leading-8 text-[#4c4438]">
					A brand that actually makes its clothing here is rare now. A lot of outdoor clothing talks loudly about merino, performance, and New Zealand design, then goes quiet on where the garments are actually made. Wild Balance is different.
				</p>
				<p class="text-lg leading-8 text-[#4c4438]">
					Designed here. Made here. Worn here - in the country we actually hunt.
				</p>
				<p class="text-base leading-7 text-[#625a4d]">
					Wild Balance is built on more than 10 years of full-time clothing experience,
					including Morphic Ltd - our previous Christchurch clothing business making custom
					merino and cotton garments for customers here and overseas.
				</p>
				<p class="text-base leading-7 text-[#625a4d]">
					We know patterns. We know machines. We know fabric. We know what it takes to make
					clothing properly.
				</p>
				<p class="text-base leading-7 text-[#625a4d]">
					This next chapter is more focused: merino hunting clothing, made here, for the country we actually hunt.
				</p>
			</div>

			<ImageFrame
				src={placeholderImages.workshop}
				alt="Placeholder image of garment makers working in a sewing workshop."
				aspect="wide"
				objectPosition="center"
			/>
		</div>
	</Section>

	<section class="bg-[#efe8db] px-5 py-16 sm:px-6 sm:py-20 lg:px-8">
		<div class="grid gap-10 lg:grid-cols-[1.05fr_0.95fr] lg:items-center">
			<div>
				<p class="text-xs font-semibold uppercase tracking-[0.24em] text-[#626b43]">Launch</p>
				<h2 class="mt-4 max-w-2xl text-3xl font-semibold tracking-normal text-[#2c271f] sm:text-4xl">
					Be part of the Wild Balance launch.
				</h2>
				<p class="mt-4 max-w-2xl text-base leading-7 text-[#625a4d]">
					Follow the first garment, get launch updates, and back a proper New Zealand-made
					merino brand - designed, cut, sewn, and hand dyed in Christchurch.
				</p>
			</div>
			<a
				href="/contact"
				class="inline-flex justify-center border border-[#2c271f] bg-[#2c271f] px-5 py-3 text-sm font-semibold text-[#f8f3e9] transition-colors hover:bg-[#3d372d]"
			>
				Register your interest
			</a>
		</div>
	</section>
</BaseLayout>
