---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ImageFrame from '../components/ImageFrame.astro';
import RegisterInterestModal from '../components/RegisterInterestModal.astro';
import Section from '../components/Section.astro';

import heroImage from '../assets/img/WildBalance_Hero1.jpg';
import heroNarrowLandscapeImage from '../assets/img/WildBalance_Hero1_NarrowLandscape.jpg';

// Replace these Unsplash URLs with your own field, garment, and workshop images when ready.
const placeholderImages = {
	hero:
		heroImage.src,
	herowide:
	    heroNarrowLandscapeImage.src,
	wool:
		'https://images.unsplash.com/photo-1550376026-7375b92bb318?auto=format&fit=crop&q=80&w=1200',
	workshop:
		'https://images.unsplash.com/photo-1753162659622-371949a713ec?auto=format&fit=crop&q=80&w=1400',
};

const practicalNotes = [
	{
		title: 'One at a time',
		text: 'This is not standard off-the-shelf clothing with a local logo stitched on. Each garment is individually made by people who know the work.',
	},
	{
		title: 'By hunters, for hunters',
		text: 'The first pieces are aimed at real hunting days: early starts, long climbs, glassing, camp, and cold weather that shifts quickly.',
	},
	{
		title: 'Built on experience',
		text: 'The makers have over 10 years of full-time clothing experience, including running Morphic Ltd from Christchurch.',
	},
];

const hoodieUses = ['Cold mornings', 'Long climbs', 'Glassing', 'Camp', 'Around the fire'];
---

<BaseLayout
	title="Wild Balance | Soft Fibre. Hard Country."
	description="Designed, cut, sewn, and hand dyed merino outdoor clothing from Christchurch, New Zealand."
>
	<Hero
		eyebrow="Not just designed here. Made here."
		title="Soft fibre. Hard country."
		subtitleParagraphs={[
			'Wild Balance started with two things we love: making clothing and exploring New Zealand’s outdoors.',
			'Our first release is a do-it-all alpine hunting hoodie, tailor-made by us in Christchurch.',
		]}
		supportParagraphs={[
			'Built for cold starts, breathable on long climbs, and warm while glassing the tops. Each hoodie is cut, sewn, and hand dyed by us, creating natural variation in tone and pattern. No two garments are exactly the same.',
			'Register your interest and help launch Wild Balance. A New Zealand-made hunting brand shaped by years behind the machines and time in the hills.',
		]}
		imageSrc={placeholderImages.herowide }
		imageAlt="Placeholder image of a hunter in a hoodie standing in front of a rock wall."
		imageObjectPosition="left"
		primaryHref="/contact"
		primaryLabel="Register Your Interest"
		primaryOpensModal
	/>

	<Section
		tone="muted"
		eyebrow="The Launch - one garment, done properly."
		title="The merino hoodie handcrafted for backcountry adventure."
	>
		<p class="max-w-4xl text-xl font-medium leading-8 text-[#3d372d] sm:text-2xl">
			We are starting with a hoodie because it is the layer us alpine hunters live in.
		</p>
		<p class="mt-5 max-w-3xl text-base leading-7 text-[#625a4d] sm:text-lg">
			A practical hood for protection from the wind and sun, reduced bulk to stop you getting snagged on the ascent, and a cut that lets you glass without fighting the garment.
		</p>
		<p class="mt-5 max-w-3xl text-base leading-7 text-[#625a4d] sm:text-lg">
			Doubled-over sleeve and body cuffs add durability where it matters, with no scratchy tags or labels in the wrong spot.
		</p>
		<a
			href="/contact"
			data-register-open
			aria-haspopup="dialog"
			aria-controls="register-interest-modal"
			class="mt-8 inline-flex rounded-[6px] border border-[#3a382f]/30 bg-[#f8f3e9]/70 px-5 py-3 text-sm font-semibold text-[#2c271f] transition-colors hover:border-[#3a382f]/60 hover:bg-[#f8f3e9]"
		>
			Get behind the first release
		</a>
		<div class="-mx-5 -mb-16 mt-10 grid gap-4 sm:-mx-6 sm:-mb-20 md:mx-0 md:mb-0 md:grid-cols-3">
			<a href={placeholderImages.hero} target="_blank" rel="noreferrer" class="block">
				<ImageFrame
					src={placeholderImages.hero}
					alt="Placeholder image of hikers moving through alpine terrain beneath snow-covered peaks."
					aspect="square"
					objectPosition="center"
				/>
			</a>
			<a href={placeholderImages.wool} target="_blank" rel="noreferrer" class="block">
				<ImageFrame
					src={placeholderImages.wool}
					alt="Placeholder close-up image of wool textile texture."
					aspect="square"
					objectPosition="center"
				/>
			</a>
			<a href={placeholderImages.workshop} target="_blank" rel="noreferrer" class="block">
				<ImageFrame
					src={placeholderImages.workshop}
					alt="Placeholder image of garment makers working in a sewing workshop."
					aspect="square"
					objectPosition="center"
				/>
			</a>
		</div>
	</Section>

	<Section
		eyebrow="THE FIRST RELEASE"
		title="How to get one."
		intro="The first Wild Balance hoodies will not be pulled from a warehouse shelf. We will be making them by hand, one-at-a-time for you to get the fit right."
	>
		<ol class="grid gap-5 md:grid-cols-2 xl:grid-cols-3">
			<li class="border border-[#2c271f]/15 bg-[#f8f3e9] p-6">
				<h3 class="text-lg font-semibold text-[#2c271f]">
					<span class="mr-2 text-xs font-semibold uppercase tracking-[0.24em] text-[#626b43]">1.</span>
					Register Your Interest
				</h3>
				<p class="mt-3 text-sm leading-6 text-[#625a4d]">
					Tell us you're keen and we will keep you in the loop as the first production gets closer.
				</p>
			</li>
			<li class="border border-[#2c271f]/15 bg-[#f8f3e9] p-6">
				<h3 class="text-lg font-semibold text-[#2c271f]">
					<span class="mr-2 text-xs font-semibold uppercase tracking-[0.24em] text-[#626b43]">2.</span>
					We Get In Touch
				</h3>
				<p class="mt-3 text-sm leading-6 text-[#625a4d]">
					We will confirm your size, colours and dye job. We'll figure out if small adjustments are
					needed - like sleeve length or body length.
				</p>
			</li>
			<li class="border border-[#2c271f]/15 bg-[#f8f3e9] p-6">
				<h3 class="text-lg font-semibold text-[#2c271f]">
					<span class="mr-2 text-xs font-semibold uppercase tracking-[0.24em] text-[#626b43]">3.</span>
					Pay Your Deposit
				</h3>
				<p class="mt-3 text-sm leading-6 text-[#625a4d]">
					A deposit secures your garment ready for cutting, dyeing and sewing.
				</p>
			</li>
			<li class="border border-[#2c271f]/15 bg-[#f8f3e9] p-6">
				<h3 class="text-lg font-semibold text-[#2c271f]">
					<span class="mr-2 text-xs font-semibold uppercase tracking-[0.24em] text-[#626b43]">4.</span>
					We Make Your Hoodie
				</h3>
				<p class="mt-3 text-sm leading-6 text-[#625a4d]">
					Your hoodie is sewn and hand dyed by us in Christchurch.
				</p>
			</li>
			<li class="border border-[#2c271f]/15 bg-[#f8f3e9] p-6">
				<h3 class="text-lg font-semibold text-[#2c271f]">
					<span class="mr-2 text-xs font-semibold uppercase tracking-[0.24em] text-[#626b43]">5.</span>
					Pay The Balance
				</h3>
				<p class="mt-3 text-sm leading-6 text-[#625a4d]">
					When your garment is complete, we'll send you photos and details. You can pay the balance then, and we will get it shipped to you.
				</p>
			</li>
			<li class="border border-[#2c271f]/15 bg-[#f8f3e9] p-6">
				<h3 class="text-lg font-semibold text-[#2c271f]">
					<span class="mr-2 text-xs font-semibold uppercase tracking-[0.24em] text-[#626b43]">6.</span>
					Get It On And Go Hunting
				</h3>
				<p class="mt-3 text-sm leading-6 text-[#625a4d]">
					We'll deliver your hoodie to you. Then it's up to you to get out there for a hunt and experience this amazing merino for yourself.
				</p>
			</li>
		</ol>
	</Section>

	<Section
		tone="muted"
		eyebrow="FEW AND FAR BETWEEN"
		title="We're not offshoring the hard part."
		intro=""
	>
		<div class="grid gap-10 lg:grid-cols-[1.05fr_0.95fr] lg:items-center">
			<div class="space-y-5">
				<p class="text-lg leading-8 text-[#4c4438]">
					A brand that actually makes its clothing here is rare now. A lot of outdoor clothing talks loudly about merino, performance, and New Zealand design, then goes quiet on where the garments are actually made. Wild Balance is taking a different path.
				</p>
				<p class="text-base leading-7 text-[#625a4d]">
					We have spent years designing, cutting, sewing, and refining garments. We have also spent years hunting, hiking, camping, and learning what clothing needs to do in our turbulent southern weather.
				</p>
				<p class="text-base leading-7 text-[#625a4d]">
Wild Balance is where those two worlds meet.				</p>
<p class="text-base leading-7 text-[#625a4d]">
Before Wild Balance, in pre-earthquake Christchurch we ran <i>Morphic</i>, a cutting-edge clothing business exporting merino hoodies around the world.
</p>
<p class="text-base leading-7 text-[#625a4d]">
Now, with new patterns refined and a sewing studio rebuilt, we are ready to make something worth backing: handmade merino hoodies for mountain missions, made one at a time in Christchurch.</p>
			</div>

			<ImageFrame
				src={placeholderImages.workshop}
				alt="Placeholder image of garment makers working in a sewing workshop."
				aspect="wide"
				objectPosition="center"
				className="-mx-5 -mb-16 sm:-mx-6 sm:-mb-20 lg:mx-0 lg:mb-0"
			/>
		</div>
	</Section>

	<section class="bg-[#efe8db] py-16 sm:py-20">
		<div class="mx-auto max-w-7xl px-5 sm:px-6 lg:px-8">
			<div class="grid gap-10 lg:grid-cols-[1.05fr_0.95fr] lg:items-center">
				<div>
					<p class="text-xs font-semibold uppercase tracking-[0.24em] text-[#626b43]">Launch</p>
					<h2 class="mt-4 max-w-3xl text-3xl font-semibold tracking-normal text-[#2c271f] sm:text-4xl">
						Be part of the Wild Balance launch.
					</h2>
					<p class="mt-4 max-w-3xl text-base leading-7 text-[#625a4d]">
						Follow the first garment, get launch updates, and back a proper New Zealand-made
						merino brand - designed, cut, sewn, and hand dyed in Christchurch.
					</p>
				</div>
				<a
					href="/contact"
					data-register-open
					aria-haspopup="dialog"
					aria-controls="register-interest-modal"
					class="cta-primary cta-attention inline-flex justify-center px-5 py-3 text-sm font-semibold"
				>
					Register Your Interest
				</a>
			</div>
		</div>
	</section>

	<RegisterInterestModal />
</BaseLayout>
