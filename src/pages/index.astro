---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Section from '../components/Section.astro';

const principles = [
	{
		title: 'Merino first',
		text: 'Natural fibre selected for warmth, breathability, and comfort across changing alpine conditions.',
	},
	{
		title: 'Made by hand',
		text: 'Cut and sewn in Christchurch by makers with deep production experience and a close eye for fit.',
	},
	{
		title: 'Quietly capable',
		text: 'Purposeful layers without loud graphics, tactical styling, or disposable seasonal noise.',
	},
];

const garmentTypes = [
	'Base layers for long climbs and cold glassing sessions',
	'Mid layers for stop-start weather and high-output movement',
	'Small-batch pieces shaped by field use and customer feedback',
];
---

<BaseLayout
	title="Wild Balance | Soft fibre. Hard country."
	description="Handmade New Zealand merino outdoor clothing from Christchurch for alpine hunters, trampers, and Southern Alps terrain."
>
	<Hero
		eyebrow="Handmade merino from Christchurch, New Zealand"
		title="Soft fibre. Hard country."
		subtitle="Premium merino outdoor clothing for aspiring alpine hunters, trampers, and people who spend their time where weather turns quickly."
		primaryHref="/contact"
		primaryLabel="Join the waitlist"
		secondaryHref="/garments"
		secondaryLabel="View garments"
	/>

	<Section
		eyebrow="Wild Balance"
		title="Built for Southern Alps terrain, made with a lighter hand."
		intro="Wild Balance is the next chapter from makers with more than 12 years of full-time clothing experience. The work is restrained, tactile, and focused on merino layers that earn their place in a pack."
	>
		<div class="grid gap-5 md:grid-cols-3">
			{
				principles.map((item) => (
					<article class="border border-[#d8d1c2]/12 bg-[#171510] p-6">
						<h3 class="text-lg font-semibold text-[#f5efe2]">{item.title}</h3>
						<p class="mt-4 text-sm leading-6 text-[#b8ae9c]">{item.text}</p>
					</article>
				))
			}
		</div>
	</Section>

	<Section
		tone="muted"
		eyebrow="Material feel"
		title="Warmth, movement, and comfort without bulk."
		intro="Merino has a rare balance: soft against skin, warm when the air drops, and steady through mixed effort. The design language stays plain so the fibre and construction can do the work."
	>
		<div class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
			<div class="material-panel min-h-[22rem]" aria-hidden="true"></div>
			<div class="grid gap-5 sm:grid-cols-2">
				<div class="border-l border-[#8f9a76]/45 pl-5">
					<h3 class="text-base font-semibold text-[#f5efe2]">Tactile by design</h3>
					<p class="mt-3 text-sm leading-6 text-[#b8ae9c]">
						Raw wool tones, clean seams, and careful proportions for garments that feel considered
						before they feel technical.
					</p>
				</div>
				<div class="border-l border-[#8f9a76]/45 pl-5">
					<h3 class="text-base font-semibold text-[#f5efe2]">Terrain aware</h3>
					<p class="mt-3 text-sm leading-6 text-[#b8ae9c]">
						Shaped for changing pace, scrub edges, exposed ridgelines, and weather that rarely
						stays polite.
					</p>
				</div>
				<div class="border-l border-[#8f9a76]/45 pl-5">
					<h3 class="text-base font-semibold text-[#f5efe2]">Small batch</h3>
					<p class="mt-3 text-sm leading-6 text-[#b8ae9c]">
						Focused runs allow fit, fabric, and construction choices to keep improving without
						drifting into mass production.
					</p>
				</div>
				<div class="border-l border-[#8f9a76]/45 pl-5">
					<h3 class="text-base font-semibold text-[#f5efe2]">Christchurch made</h3>
					<p class="mt-3 text-sm leading-6 text-[#b8ae9c]">
						The work starts close to the hills, with local patterning, sewing, and practical
						refinement.
					</p>
				</div>
			</div>
		</div>
	</Section>

	<Section
		eyebrow="Garments"
		title="Early pieces will focus on dependable merino layers."
		intro="The first range is being shaped around the pieces that see the most use: simple layers, strong fabric choices, and patterns that move cleanly under packs and outer shells."
	>
		<div class="grid gap-5 md:grid-cols-3">
			{
				garmentTypes.map((item) => (
					<article class="flex min-h-48 flex-col justify-between border border-[#d8d1c2]/12 bg-[#14130f] p-6">
						<div class="wool-swatch mb-8 h-24" aria-hidden="true"></div>
						<h3 class="text-lg font-semibold leading-7 text-[#f5efe2]">{item}</h3>
					</article>
				))
			}
		</div>
	</Section>

	<section class="bg-[#0c0b08] px-5 py-16 sm:px-6 sm:py-20 lg:px-8">
		<div class="mx-auto grid max-w-7xl gap-8 border-y border-[#d8d1c2]/10 py-10 md:grid-cols-[1fr_auto] md:items-center">
			<div>
				<p class="text-xs font-semibold uppercase tracking-[0.24em] text-[#8f9a76]">Waitlist</p>
				<h2 class="mt-4 max-w-2xl text-3xl font-semibold tracking-normal text-[#f5efe2] sm:text-4xl">
					Follow the first Wild Balance release.
				</h2>
				<p class="mt-4 max-w-2xl text-base leading-7 text-[#b8ae9c]">
					Join for launch updates, early garment notes, and made-to-order availability.
				</p>
			</div>
			<a
				href="/contact"
				class="inline-flex justify-center border border-[#d8d1c2] bg-[#d8d1c2] px-5 py-3 text-sm font-semibold text-[#14130f] transition-colors hover:bg-[#f5efe2]"
			>
				Join the waitlist
			</a>
		</div>
	</section>
</BaseLayout>
