---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';

const steps = [
	{
		title: 'Design',
		text: 'Start with the hunting day: climbing, glassing, layering, cold starts, and pack contact.',
	},
	{
		title: 'Cut',
		text: 'Cut the fabric in Christchurch, with the pattern and material handled by the same people making the garment.',
	},
	{
		title: 'Sew',
		text: 'Sew each piece one at a time, with practical attention to fit, comfort, and durability.',
	},
	{
		title: 'Hand dye',
		text: 'Finish the garment by hand dyeing it here, keeping the colour and feel tied to the making process.',
	},
];
---

<BaseLayout
	title="Process | Wild Balance"
	description="How Wild Balance approaches handmade merino outdoor clothing from Christchurch."
>
	<Section
		eyebrow="Process"
		title="Designed, cut, sewn, and hand dyed in Christchurch."
		intro="Wild Balance keeps the hard work close. Not just the idea. The making."
	>
		<ol class="grid gap-5 md:grid-cols-2">
			{
				steps.map((step, index) => (
					<li class="border border-[#2c271f]/15 bg-[#f8f3e9] p-6">
						<p class="text-xs font-semibold uppercase tracking-[0.24em] text-[#626b43]">
							{String(index + 1).padStart(2, '0')}
						</p>
						<h2 class="mt-8 text-2xl font-semibold text-[#2c271f]">{step.title}</h2>
						<p class="mt-4 text-sm leading-6 text-[#625a4d]">{step.text}</p>
					</li>
				))
			}
		</ol>
	</Section>

	<Section
		tone="deep"
		title="We are not outsourcing the hard part."
		intro="The making is the point. More than 12 years of full-time clothing production sits behind the first Wild Balance garments, from pattern through to the final hand-dyed finish."
		narrow
	/>
</BaseLayout>
