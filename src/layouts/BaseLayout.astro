---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
	image?: string;
	robots?: string;
}

const {
	title = 'Wild Balance | Handmade New Zealand Merino',
	description = 'Handmade merino outdoor clothing from Christchurch, New Zealand.',
	image = '/WILD_BALANCE_3D.png',
	robots = 'index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1',
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? 'https://wildbalance.nz').href;
const socialImage = new URL(image, Astro.site ?? 'https://wildbalance.nz').href;
const siteName = 'Wild Balance';

const structuredData = [
	{
		'@context': 'https://schema.org',
		'@type': 'Organization',
		name: siteName,
		url: canonicalUrl,
		logo: new URL('/favicon.svg', Astro.site ?? 'https://wildbalance.nz').href,
		description,
	},
	{
		'@context': 'https://schema.org',
		'@type': 'WebSite',
		name: siteName,
		url: new URL('/', Astro.site ?? 'https://wildbalance.nz').href,
		description,
	},
];
---

<!doctype html>
<html lang="en-NZ">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<link rel="canonical" href={canonicalUrl} />
		<meta name="description" content={description} />
		<meta name="robots" content={robots} />
		<meta name="author" content={siteName} />
		<meta name="theme-color" content="#efe8db" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<meta property="og:site_name" content={siteName} />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:image" content={socialImage} />
		<meta property="og:image:alt" content={title} />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={socialImage} />
		<title>{title}</title>
		<script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
	</head>
	<body>
		<a class="skip-link" href="#main">Skip to content</a>
		<div class="min-h-screen bg-[#efe8db] text-[#2c271f]">
			<Header />
			<main id="main">
				<slot />
			</main>
			<Footer />
		</div>
	</body>
</html>
