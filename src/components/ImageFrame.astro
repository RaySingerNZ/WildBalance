---
interface Props {
	src: string;
	alt: string;
	aspect?: 'landscape' | 'portrait' | 'hero' | 'wide' | 'square';
	aspectClassName?: string;
	caption?: string;
	loading?: 'eager' | 'lazy';
	objectPosition?: string;
	className?: string;
}

const {
	src,
	alt,
	aspect = 'landscape',
	aspectClassName,
	caption,
	loading = 'lazy',
	objectPosition = 'center',
	className = '',
} = Astro.props;

const aspectClass = {
	landscape: 'aspect-[4/3]',
	portrait: 'aspect-[4/5]',
	hero: 'aspect-[3/4]',
	wide: 'aspect-[16/10]',
	square: 'aspect-square',
}[aspect];
---

<figure class={className}>
	<div class:list={['overflow-hidden border border-[#2c271f]/15 bg-[#d8cdbb]', aspectClassName || aspectClass]}>
		<img
			src={src}
			alt={alt}
			loading={loading}
			decoding="async"
			class="h-full w-full object-cover"
			style={`object-position: ${objectPosition};`}
		/>
	</div>
	{
		caption && (
			<figcaption class="mt-3 text-xs leading-5 text-[#6f6658]">
				{caption}
			</figcaption>
		)
	}
</figure>
