---
interface Props {
	id?: string;
	eyebrow?: string;
	title?: string;
	intro?: string;
	tone?: 'default' | 'muted' | 'deep';
	narrow?: boolean;
}

const {
	id,
	eyebrow,
	title,
	intro,
	tone = 'default',
	narrow = false,
} = Astro.props;
---

<section
	id={id}
	class:list={[
		'border-b border-[#d8d1c2]/10 py-16 sm:py-20',
		tone === 'default' && 'bg-[#11100c]',
		tone === 'muted' && 'bg-[#171510]',
		tone === 'deep' && 'bg-[#0c0b08]',
	]}
>
	<div class:list={['mx-auto px-5 sm:px-6 lg:px-8', narrow ? 'max-w-4xl' : 'max-w-7xl']}>
		{
			(eyebrow || title || intro) && (
				<header class="mb-10 max-w-3xl">
					{
						eyebrow && (
							<p class="mb-4 text-xs font-semibold uppercase tracking-[0.24em] text-[#8f9a76]">
								{eyebrow}
							</p>
						)
					}
					{title && <h2 class="text-3xl font-semibold tracking-normal text-[#f5efe2] sm:text-4xl">{title}</h2>}
					{intro && <p class="mt-5 text-base leading-7 text-[#b8ae9c] sm:text-lg">{intro}</p>}
				</header>
			)
		}
		<slot />
	</div>
</section>
