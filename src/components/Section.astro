---
interface Props {
	id?: string;
	eyebrow?: string;
	title?: string;
	intro?: string;
	introClass?: string;
	tone?: 'default' | 'muted' | 'deep';
	narrow?: boolean;
}

const {
	id,
	eyebrow,
	title,
	intro,
	introClass = '',
	tone = 'default',
	narrow = false,
} = Astro.props;

const titleParts = title?.split('Wild Balance') ?? [];
---

<section
	id={id}
	class:list={[
		'border-b border-[#2c271f]/10 pb-16 pt-10 sm:pb-20 sm:pt-14 lg:py-20',
		tone === 'default' && 'bg-[#efe8db]',
		tone === 'muted' && 'bg-[#e4d8c7]',
		tone === 'deep' && 'bg-[#2c271f]',
	]}
>
	<div class:list={['mx-auto px-5 sm:px-6 lg:px-8', narrow ? 'max-w-4xl' : 'max-w-7xl']}>
		{
			(eyebrow || title || intro) && (
				<header class="mb-10 max-w-3xl">
					{
						eyebrow && (
							<p class:list={['mb-4 text-xs font-semibold uppercase tracking-[0.24em]', tone === 'deep' ? 'text-[#b8c08c]' : 'text-[#626b43]']}>
								{eyebrow}
							</p>
						)
					}
					{
						title && (
							<h2 class:list={['text-3xl font-semibold tracking-normal sm:text-4xl', tone === 'deep' ? 'text-[#f8f3e9]' : 'text-[#2c271f]']}>
								{
									titleParts.length > 1
										? titleParts.map((part, index) => (
												<>
													{part}
													{
														index < titleParts.length - 1 && (
															<span class="font-host-grotesk">Wild Balance</span>
														)
													}
												</>
											))
										: title
								}
							</h2>
						)
					}
					{intro && (
						<p
							class:list={[
								'mt-5',
								introClass || 'text-base leading-7 sm:text-lg',
								tone === 'deep' ? 'text-[#d8cdbb]' : 'text-[#625a4d]',
							]}
						>
							{intro}
						</p>
					)}
				</header>
			)
		}
		<slot />
	</div>
</section>
