<form class="grid gap-5" method="get" action="/contact">
	<div class="grid gap-5 sm:grid-cols-2">
		<div>
			<label for="name" class="block text-sm font-medium text-[#2c271f]">Name</label>
			<input
				id="name"
				name="name"
				type="text"
				autocomplete="name"
				required
				class="mt-2 w-full border border-[#2c271f]/20 bg-[#f8f3e9] px-4 py-3 text-[#2c271f] outline-none transition-colors placeholder:text-[#8b8172] focus:border-[#626b43]"
			/>
		</div>
		<div>
			<label for="email" class="block text-sm font-medium text-[#2c271f]">Email</label>
			<input
				id="email"
				name="email"
				type="email"
				autocomplete="email"
				required
				class="mt-2 w-full border border-[#2c271f]/20 bg-[#f8f3e9] px-4 py-3 text-[#2c271f] outline-none transition-colors placeholder:text-[#8b8172] focus:border-[#626b43]"
			/>
		</div>
	</div>

	<div>
		<label for="interest" class="block text-sm font-medium text-[#2c271f]">Primary interest</label>
		<select
			id="interest"
			name="interest"
			class="mt-2 w-full border border-[#2c271f]/20 bg-[#f8f3e9] px-4 py-3 text-[#2c271f] outline-none transition-colors focus:border-[#626b43]"
		>
			<option>Merino mid-layer hoodie</option>
			<option>Made-to-order enquiry</option>
			<option>Hand dyed garments</option>
			<option>General updates</option>
		</select>
	</div>

	<div>
		<label for="message" class="block text-sm font-medium text-[#2c271f]">Message</label>
		<textarea
			id="message"
			name="message"
			rows="5"
			class="mt-2 w-full resize-y border border-[#2c271f]/20 bg-[#f8f3e9] px-4 py-3 text-[#2c271f] outline-none transition-colors placeholder:text-[#8b8172] focus:border-[#626b43]"
		></textarea>
	</div>

	<label class="flex gap-3 text-sm leading-6 text-[#625a4d]">
		<input
			type="checkbox"
			name="updates"
			value="yes"
			class="mt-1 h-4 w-4 border-[#2c271f]/30 bg-[#f8f3e9] text-[#626b43]"
		/>
		<span>Send me launch updates and notes on the first Christchurch-made garments.</span>
	</label>

	<button
		type="submit"
		class="w-full border border-[#2c271f] bg-[#2c271f] px-5 py-3 text-sm font-semibold text-[#f8f3e9] transition-colors hover:bg-[#3d372d] sm:w-auto"
	>
		Join the waitlist
	</button>
</form>
