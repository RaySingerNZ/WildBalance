---
import ImageFrame from './ImageFrame.astro';

interface Props {
	eyebrow?: string;
	title: string;
	subtitle?: string;
	support?: string;
	imageSrc?: string;
	imageAlt?: string;
	imageObjectPosition?: string;
	primaryHref?: string;
	primaryLabel?: string;
	secondaryHref?: string;
	secondaryLabel?: string;
}

const {
	eyebrow,
	title,
	subtitle,
	support,
	imageSrc,
	imageAlt = '',
	imageObjectPosition = 'center',
	primaryHref,
	primaryLabel,
	secondaryHref,
	secondaryLabel,
} = Astro.props;

const isBrandTagline = title === 'Soft Fibre. Hard Country.';
---

<section class="relative isolate overflow-hidden border-b border-[#2c271f]/10 bg-[#efe8db]">
	<div class="hero-visual absolute inset-0" aria-hidden="true"></div>
	<div class="absolute inset-0 bg-[#efe8db]/30" aria-hidden="true"></div>

	<div class:list={[
		'relative mx-auto max-w-7xl gap-10 px-5 py-12 sm:px-6 sm:py-16 lg:min-h-[72vh] lg:items-end lg:px-8 lg:py-24',
		imageSrc ? 'lg:grid lg:grid-cols-[1fr_0.78fr]' : 'lg:flex',
	]}>
		<div class="max-w-4xl lg:pb-4">
			{
				eyebrow && (
					<p class="mb-5 text-xs font-semibold uppercase tracking-[0.24em] text-[#626b43]">
						{eyebrow}
					</p>
				)
			}
			<h1 class="max-w-3xl text-5xl font-semibold leading-[0.95] tracking-normal text-[#2c271f] sm:text-6xl lg:text-7xl">
				{
					isBrandTagline ? (
						<>
							<span class="font-signpainter block text-[1.16em] font-normal leading-[0.82] sm:inline">
								Soft Fibre.
							</span>{' '}
							<span class="font-host-grotesk block sm:inline">Hard Country.</span>
						</>
					) : (
						title
					)
				}
			</h1>
			{
				subtitle && (
					<p class="mt-6 max-w-2xl text-xl font-medium leading-8 text-[#3d372d] sm:text-2xl">
						{subtitle}
					</p>
				)
			}
			{support && <p class="mt-5 max-w-2xl text-base leading-7 text-[#625a4d] sm:text-lg">{support}</p>}
			{
				(primaryHref || secondaryHref) && (
					<div class="mt-8 flex flex-wrap gap-3">
						{
							primaryHref && primaryLabel && (
								<a
									href={primaryHref}
									class="border border-[#2c271f] bg-[#2c271f] px-5 py-3 text-sm font-semibold text-[#f8f3e9] transition-colors hover:bg-[#3d372d]"
								>
									{primaryLabel}
								</a>
							)
						}
						{
							secondaryHref && secondaryLabel && (
								<a
									href={secondaryHref}
									class="border border-[#3a382f]/30 bg-[#f8f3e9]/70 px-5 py-3 text-sm font-semibold text-[#2c271f] transition-colors hover:border-[#3a382f]/60 hover:bg-[#f8f3e9]"
								>
									{secondaryLabel}
								</a>
							)
						}
					</div>
				)
			}
		</div>
		{
			imageSrc && (
				<ImageFrame
					src={imageSrc}
					alt={imageAlt}
					aspectClassName="aspect-[16/10] lg:aspect-square"
					loading="eager"
					objectPosition={imageObjectPosition}
					className="mt-10 lg:mt-0 lg:self-end"
				/>
			)
		}
	</div>
</section>
