---
import ImageFrame from './ImageFrame.astro';

interface Props {
	eyebrow?: string;
	title: string;
	subtitle?: string;
	subtitleParagraphs?: string[];
	support?: string;
	supportParagraphs?: string[];
	imageSrc?: string;
	imageAlt?: string;
	imageObjectPosition?: string;
	primaryHref?: string;
	primaryLabel?: string;
	primaryOpensModal?: boolean;
	secondaryHref?: string;
	secondaryLabel?: string;
}

const {
	eyebrow,
	title,
	subtitle,
	subtitleParagraphs,
	support,
	supportParagraphs,
	imageSrc,
	imageAlt = '',
	imageObjectPosition = 'center',
	primaryHref,
	primaryLabel,
	primaryOpensModal = false,
	secondaryHref,
	secondaryLabel,
} = Astro.props;

const isBrandTagline = title.toLowerCase() === 'soft fibre. hard country.';
const subtitleBlocks = subtitleParagraphs ?? (subtitle ? [subtitle] : []);
const supportBlocks = supportParagraphs ?? (support ? [support] : []);
---

<section class="relative isolate overflow-hidden border-b border-[#2c271f]/10 bg-[#efe8db]">
	<div class="hero-visual absolute inset-0" aria-hidden="true"></div>
	<div class="absolute inset-0 bg-[#efe8db]/30" aria-hidden="true"></div>

	<div class:list={[
		'relative mx-auto max-w-7xl gap-10 px-5 py-12 sm:px-6 sm:py-16 lg:min-h-[72vh] lg:items-start lg:px-8 lg:py-16',
		imageSrc ? 'lg:grid lg:grid-cols-[1fr_0.78fr]' : 'lg:flex',
	]}>
		<div class="max-w-4xl lg:pt-4">
			{
				eyebrow && (
					<p class="mb-5 text-xs font-semibold uppercase tracking-[0.24em] text-[#626b43]">
						{eyebrow}
					</p>
				)
			}
			<h1 class="max-w-3xl text-5xl font-semibold leading-[0.95] tracking-normal text-[#2c271f] sm:text-6xl lg:text-7xl">
				{
					isBrandTagline ? (
						<>
							<span class="font-signpainter block whitespace-nowrap text-[1.16em] font-normal leading-[0.82]">
								Soft fibre.
							</span>
							<span class="font-host-grotesk block whitespace-nowrap">Hard country.</span>
						</>
					) : (
						title
					)
				}
			</h1>
			{
				subtitleBlocks.length > 0 && (
					<div class="mt-6 max-w-3xl space-y-4 text-xl font-medium leading-8 text-[#3d372d] sm:text-2xl">
						{subtitleBlocks.map((paragraph) => <p>{paragraph}</p>)}
					</div>
				)
			}
			{
				supportBlocks.length > 0 && (
					<div class="mt-5 max-w-3xl space-y-4 text-base leading-7 text-[#625a4d] sm:text-lg">
						{supportBlocks.map((paragraph) => <p>{paragraph}</p>)}
					</div>
				)
			}
			{
				(primaryHref || secondaryHref) && (
					<div class="mt-8 flex flex-wrap gap-3">
						{
							primaryHref && primaryLabel && (
								<a
									href={primaryHref}
									data-register-open={primaryOpensModal ? true : undefined}
									aria-haspopup={primaryOpensModal ? 'dialog' : undefined}
									aria-controls={primaryOpensModal ? 'register-interest-modal' : undefined}
									class="cta-primary cta-attention inline-flex justify-center px-5 py-3 text-sm font-semibold"
								>
									{primaryLabel}
								</a>
							)
						}
						{
							secondaryHref && secondaryLabel && (
								<a
									href={secondaryHref}
									class="border border-[#3a382f]/30 bg-[#f8f3e9]/70 px-5 py-3 text-sm font-semibold text-[#2c271f] transition-colors hover:border-[#3a382f]/60 hover:bg-[#f8f3e9]"
								>
									{secondaryLabel}
								</a>
							)
						}
					</div>
				)
			}
		</div>
		{
			imageSrc && (
				<ImageFrame
					src={imageSrc}
					alt={imageAlt}
					aspectClassName="aspect-[16/10] lg:aspect-square"
					loading="eager"
					objectPosition={imageObjectPosition}
					className="-mx-5 -mb-12 mt-10 sm:-mx-6 sm:-mb-16 lg:mx-0 lg:mb-0 lg:mt-0 lg:self-end"
				/>
			)
		}
	</div>
</section>
