---
interface Props {
	buttonLabel?: string;
	showIntro?: boolean;
}

const { buttonLabel = 'Register your interest', showIntro = true } = Astro.props;
---

<form
	class="grid gap-5"
	name="contact-page"
	method="POST"
	action="/thanks"
	data-netlify="true"
	netlify-honeypot="bot-field"
>
	<input type="hidden" name="source" value="contact-page" />
	<p class="hidden">
		<label>
			Don’t fill this out if you’re human:
			<input name="bot-field" />
		</label>
	</p>

	{
		showIntro && (
			<div class="space-y-3">
				<h2 class="text-xl font-semibold text-[#2c271f]">Register your interest in the first Wild Balance release.</h2>
				<p class="text-sm leading-6 text-[#625a4d]">
					Send us your name, email, and anything useful about what you are after - size, fit,
					hunting use, colours, or whether you just want launch updates.
				</p>
			</div>
		)
	}

	<div class="grid gap-5 sm:grid-cols-2">
		<div>
			<label for="name" class="block text-sm font-medium text-[#2c271f]">Name</label>
			<input
				id="name"
				name="name"
				type="text"
				autocomplete="name"
				required
				class="mt-2 w-full rounded-[6px] border border-[#2c271f]/20 bg-[#f8f3e9] px-4 py-3 text-[#2c271f] outline-none transition-colors placeholder:text-[#8b8172] focus:border-[#626b43]"
			/>
		</div>
		<div>
			<label for="email" class="block text-sm font-medium text-[#2c271f]">Email</label>
			<input
				id="email"
				name="email"
				type="email"
				autocomplete="email"
				required
				class="mt-2 w-full rounded-[6px] border border-[#2c271f]/20 bg-[#f8f3e9] px-4 py-3 text-[#2c271f] outline-none transition-colors placeholder:text-[#8b8172] focus:border-[#626b43]"
			/>
		</div>
	</div>

	<div>
		<label for="message" class="block text-sm font-medium text-[#2c271f]">Message <span class="font-normal text-[#625a4d]">(optional)</span></label>
		<textarea
			id="message"
			name="message"
			rows="4"
			class="mt-2 w-full resize-y rounded-[6px] border border-[#2c271f]/20 bg-[#f8f3e9] px-4 py-3 text-[#2c271f] outline-none transition-colors placeholder:text-[#8b8172] focus:border-[#626b43]"
		></textarea>
	</div>

	<button
		type="submit"
		class="cta-primary cta-attention inline-flex w-full justify-center px-5 py-3 text-sm font-semibold sm:w-auto"
	>
		{buttonLabel}
	</button>
</form>
