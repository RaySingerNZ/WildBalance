---
import wordmarkLogo from '../assets/logo/WildBalance_WordOnly_Brown_SVG.svg';

const navItems = [
	{ href: '/', label: 'Home' },
	{ href: '/about', label: 'About' },
	{ href: '/contact', label: 'Contact' },
];

const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
const registerOpensModal = pathname === '/';
---

<header class="font-host-grotesk sticky top-0 z-50 border-b border-[#2c271f]/10 bg-[#efe8db]/95 backdrop-blur">
	<div class="mx-auto flex max-w-7xl items-center justify-between gap-5 px-5 py-3.5 sm:px-6 lg:grid lg:grid-cols-[1fr_auto_1fr] lg:items-center lg:px-8">
		<nav class="hidden items-center gap-1 md:flex lg:col-start-1 lg:justify-self-start" aria-label="Primary navigation">
			{
				navItems.map((item) => {
					const itemPath = item.href.replace(/\/$/, '') || '/';
					const isActive = pathname === itemPath;

					return (
						<a
							href={item.href}
							aria-current={isActive ? 'page' : undefined}
							class:list={[
								'border-b border-transparent px-3 py-2 text-sm font-medium transition-colors lg:text-base lg:font-semibold',
								isActive
									? 'border-[#626b43] text-[#2c271f]'
									: 'text-[#6f6658] hover:text-[#2c271f]',
							]}
						>
							{item.label}
						</a>
					);
				})
			}
		</nav>

		<a href="/" class="flex min-w-0 items-center gap-3 lg:col-start-2 lg:justify-self-center" aria-label="Wild Balance home">
			<img
				src={wordmarkLogo.src}
				alt="Wild Balance"
				class="h-8 w-auto shrink-0 object-contain sm:h-9"
			/>
		</a>

		<a
			href="/contact"
			data-register-open={registerOpensModal ? true : undefined}
			aria-haspopup={registerOpensModal ? 'dialog' : undefined}
			aria-controls={registerOpensModal ? 'register-interest-modal' : undefined}
			class="cta-primary hidden justify-center px-4 py-2 text-sm font-medium md:inline-flex lg:col-start-3 lg:justify-self-end"
		>
			Register Your Interest
		</a>
	</div>

	<nav class="flex gap-1 overflow-x-auto border-t border-[#2c271f]/10 px-4 py-2 md:hidden" aria-label="Mobile navigation">
		{
			navItems.map((item) => {
				const itemPath = item.href.replace(/\/$/, '') || '/';
				const isActive = pathname === itemPath;

				return (
					<a
						href={item.href}
						aria-current={isActive ? 'page' : undefined}
						class:list={[
							'whitespace-nowrap px-3 py-2 text-sm transition-colors',
							isActive ? 'text-[#2c271f]' : 'text-[#6f6658]',
						]}
					>
						{item.label}
					</a>
				);
			})
		}
	</nav>
</header>
