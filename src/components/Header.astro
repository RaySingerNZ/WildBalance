---
const navItems = [
	{ href: '/', label: 'Home' },
	{ href: '/about', label: 'About' },
	{ href: '/contact', label: 'Contact' },
];

const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
const registerOpensModal = pathname === '/';
---

<header class="font-host-grotesk sticky top-0 z-50 border-b border-[#2c271f]/10 bg-[#efe8db]/95 backdrop-blur">
	<div class="mx-auto flex max-w-7xl items-center justify-between gap-5 px-5 py-3.5 sm:px-6 lg:px-8">
		<a href="/" class="flex min-w-0 items-center gap-3" aria-label="Wild Balance home">
			<img
				src="/WILD_BALANCE_3D.png"
				alt=""
				width="40"
				height="40"
				class="h-10 w-10 shrink-0 object-contain"
				aria-hidden="true"
			/>
			<span class="min-w-0">
				<span class="font-host-grotesk block text-xl font-semibold uppercase tracking-[0.16em] text-[#2c271f]">Wild Balance</span>
			</span>
		</a>

		<nav class="hidden items-center gap-1 md:flex" aria-label="Primary navigation">
			{
				navItems.map((item) => {
					const itemPath = item.href.replace(/\/$/, '') || '/';
					const isActive = pathname === itemPath;

					return (
						<a
							href={item.href}
							aria-current={isActive ? 'page' : undefined}
							class:list={[
								'border-b border-transparent px-3 py-2 text-sm transition-colors',
								isActive
									? 'border-[#626b43] text-[#2c271f]'
									: 'text-[#6f6658] hover:text-[#2c271f]',
							]}
						>
							{item.label}
						</a>
					);
				})
			}
		</nav>

		<a
			href="/contact"
			data-register-open={registerOpensModal ? true : undefined}
			aria-haspopup={registerOpensModal ? 'dialog' : undefined}
			aria-controls={registerOpensModal ? 'register-interest-modal' : undefined}
			class="cta-primary hidden justify-center px-4 py-2 text-sm font-medium md:inline-flex"
		>
			Register Your Interest
		</a>
	</div>

	<nav class="flex gap-1 overflow-x-auto border-t border-[#2c271f]/10 px-4 py-2 md:hidden" aria-label="Mobile navigation">
		{
			navItems.map((item) => {
				const itemPath = item.href.replace(/\/$/, '') || '/';
				const isActive = pathname === itemPath;

				return (
					<a
						href={item.href}
						aria-current={isActive ? 'page' : undefined}
						class:list={[
							'whitespace-nowrap px-3 py-2 text-sm transition-colors',
							isActive ? 'text-[#2c271f]' : 'text-[#6f6658]',
						]}
					>
						{item.label}
					</a>
				);
			})
		}
	</nav>
</header>
