---
const navItems = [
	{ href: '/', label: 'Home' },
	{ href: '/about', label: 'About' },
	{ href: '/garments', label: 'Garments' },
	{ href: '/process', label: 'Process' },
	{ href: '/contact', label: 'Contact' },
];

const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<header class="sticky top-0 z-50 border-b border-[#d8d1c2]/10 bg-[#11100c]/90 backdrop-blur">
	<div class="mx-auto flex max-w-7xl items-center justify-between gap-5 px-5 py-4 sm:px-6 lg:px-8">
		<a href="/" class="flex min-w-0 items-center gap-3" aria-label="Wild Balance home">
			<span class="flex h-10 w-10 shrink-0 items-center justify-center border border-[#d8d1c2]/30 bg-[#d8d1c2]/10 text-[0.68rem] font-semibold tracking-[0.18em] text-[#eee8dc]">
				WB
			</span>
			<span class="min-w-0">
				<span class="block text-sm font-semibold uppercase tracking-[0.2em] text-[#f5efe2]">Wild Balance</span>
				<span class="mt-1 hidden text-xs text-[#b8ae9c] sm:block">Christchurch, New Zealand</span>
			</span>
		</a>

		<nav class="hidden items-center gap-1 md:flex" aria-label="Primary navigation">
			{
				navItems.map((item) => {
					const itemPath = item.href.replace(/\/$/, '') || '/';
					const isActive = pathname === itemPath;

					return (
						<a
							href={item.href}
							aria-current={isActive ? 'page' : undefined}
							class:list={[
								'px-3 py-2 text-sm transition-colors',
								isActive
									? 'text-[#f5efe2]'
									: 'text-[#b8ae9c] hover:text-[#f5efe2]',
							]}
						>
							{item.label}
						</a>
					);
				})
			}
		</nav>

		<a
			href="/contact"
			class="hidden border border-[#d8d1c2]/25 px-4 py-2 text-sm font-medium text-[#f5efe2] transition-colors hover:border-[#d8d1c2]/50 hover:bg-[#d8d1c2]/10 md:inline-flex"
		>
			Waitlist
		</a>
	</div>

	<nav class="flex gap-1 overflow-x-auto border-t border-[#d8d1c2]/10 px-4 py-2 md:hidden" aria-label="Mobile navigation">
		{
			navItems.map((item) => {
				const itemPath = item.href.replace(/\/$/, '') || '/';
				const isActive = pathname === itemPath;

				return (
					<a
						href={item.href}
						aria-current={isActive ? 'page' : undefined}
						class:list={[
							'whitespace-nowrap px-3 py-2 text-sm transition-colors',
							isActive ? 'text-[#f5efe2]' : 'text-[#b8ae9c]',
						]}
					>
						{item.label}
					</a>
				);
			})
		}
	</nav>
</header>
