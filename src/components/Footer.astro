---
const footerLinks = [
	{ href: '/about', label: 'About' },
	{ href: '/garments', label: 'Garments' },
	{ href: '/process', label: 'Process' },
	{ href: '/contact', label: 'Contact' },
];
---

<footer class="border-t border-[#2c271f]/10 bg-[#2c271f]">
	<div class="mx-auto grid max-w-7xl gap-10 px-5 py-12 sm:px-6 md:grid-cols-[1.4fr_1fr] lg:px-8">
		<div>
			<a href="/" class="inline-flex items-center gap-3" aria-label="Wild Balance home">
				<img
					src="/WILD_BALANCE_3D.png"
					alt=""
					width="36"
					height="36"
					class="h-9 w-9 shrink-0 object-contain"
					aria-hidden="true"
				/>
				<span class="font-host-grotesk text-sm font-semibold uppercase tracking-[0.2em] text-[#f8f3e9]">Wild Balance</span>
			</a>
			<p class="mt-5 max-w-xl text-sm leading-6 text-[#d8cdbb]">
				Designed, cut, sewn, and hand dyed in Christchurch. Merino outdoor clothing made one
				at a time for big country and rough weather.
			</p>
		</div>

		<div class="grid gap-5 sm:grid-cols-2">
			<nav aria-label="Footer navigation">
				<h2 class="text-xs font-semibold uppercase tracking-[0.22em] text-[#b8c08c]">Explore</h2>
				<ul class="mt-4 space-y-3">
					{
						footerLinks.map((link) => (
							<li>
								<a href={link.href} class="text-sm text-[#d8cdbb] transition-colors hover:text-[#f8f3e9]">
									{link.label}
								</a>
							</li>
						))
					}
				</ul>
			</nav>

			<div>
				<h2 class="text-xs font-semibold uppercase tracking-[0.22em] text-[#b8c08c]">Origin</h2>
				<p class="mt-4 text-sm leading-6 text-[#d8cdbb]">
					Christchurch made. One at a time. Merino focused.
				</p>
			</div>
		</div>
	</div>
	<div class="border-t border-[#d8cdbb]/10 px-5 py-5 text-center text-xs text-[#b9ae9c]">
		&copy; {new Date().getFullYear()} <span class="font-host-grotesk text-[#f8f3e9]">Wild Balance.</span>
		<span class="font-signpainter text-base text-[#f8f3e9]">Soft Fibre.</span>
		<span class="font-host-grotesk">Hard Country.</span>
	</div>
</footer>
